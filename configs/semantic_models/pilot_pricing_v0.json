            "aggregation": "count_distinct",
            "field": "opportunity_id",
            "filter": "outcome = won"
          },
          {
            "name": "lost_opportunity_count",
            "label": "Lost Opportunities",
            "aggregation": "count_distinct",
            "field": "opportunity_id",
            "filter": "outcome = lost"
          },
          {
            "name": "win_rate",
