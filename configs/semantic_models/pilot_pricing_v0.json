            "grain": [
              "year",
              "quarter",
              "month",
              "day"
            ]
          },
          {
            "name": "close_date",
            "label": "Close Date",
            "grain": [
              "year",
              "quarter",
              "month",
              "day"
            ]
          },
          {
            "name": "expected_start_date",
            "label": "Expected Start Date",
            "grain": [
              "year",
              "quarter",
              "month",
              "day"
            ]
          }
        ],
        "ambiguity_flags": [
          "The pilot seed contains only closed opportunities even though the source schema also allows open opportunities.",
          "segment and sales_region also exist on accounts; in v0 they should be treated as deal-time attributes rather than a conformed account dimension.",
          "total_quote_amount is sparsely populated and may not reconcile exactly to line-item totals or price snapshot totals."
        ]
