{
  "semantic_model": {
    "name": "pilot_pricing_v0",
    "version": "v0",
    "status": "bootstrap_reviewed",
    "purpose": "Reviewed bootstrap semantic contract for the imported pilot pricing seed. This model is intended to guide a visualization agent before any raw-SQL-first query generation is introduced.",
    "source_dataset": {
      "root": "data/seed",
      "manifest_file": "data/seed/manifest.json",
      "approval_manifest_file": "data/seed/approval_manifest.json",
      "dataset_version": "module3_seed_v1",
      "generation_seed": 20260414
    },
    "evidence": [
      "data/seed/*.csv",
      "data/seed/manifest.json",
      "data/seed/approval_manifest.json",
      "../PricingProject/src/pricing_foundation/schema.py",
      "../PricingProject/docs/schema.md"
    ],
    "modeling_principles": [
      "Prefer explicit entity grain and approved joins over inferred shortcuts.",
      "Keep business labels friendly, but preserve source-field traceability.",
      "Mark ambiguous fields for review instead of asserting strong semantics.",
      "Treat this as a pilot semantic contract, not a permanent warehouse model."
    ],
    "entities": {
      "accounts": {
        "label": "Accounts",
        "synonyms": [
          "customers",
          "companies"
        ],
        "role": "dimension",
        "grain": "one row per account",
        "source_file": "data/seed/accounts.csv",
        "primary_key": "account_id",
        "default_label": "account_name",
        "identifiers": [
          "account_id",
          "account_external_id"
        ],
        "dimensions": [
          {
            "name": "account_name",
            "label": "Account",
            "type": "string",
            "synonyms": [
              "customer name",
              "company name"
            ]
          },
          {
            "name": "segment",
            "label": "Account Segment",
            "type": "string"
          },
          {
            "name": "industry",
            "label": "Industry",
            "type": "string"
          },
          {
            "name": "sales_region",
            "label": "Account Sales Region",
            "type": "string",
            "synonyms": [
              "region"
            ]
          },
          {
            "name": "country_code",
            "label": "Country Code",
            "type": "string"
          },
          {
            "name": "employee_band",
            "label": "Employee Band",
            "type": "string"
          },
          {
            "name": "annual_revenue_band",
            "label": "Revenue Band",
            "type": "string"
          },
          {
            "name": "customer_status",
            "label": "Customer Status",
            "type": "string"
          }
        ],
        "measures": [
          {
            "name": "account_count",
            "label": "Accounts",
            "aggregation": "count_distinct",
            "field": "account_id"
          }
        ],
        "time_dimensions": [],
        "ambiguity_flags": [
          "parent_account_id is present in the source schema but is unpopulated in the pilot seed, so parent-child account hierarchy is excluded from v0."
        ]
      },
